  u2:displayName "Neha Kulkarni" ;
  u2:learnerId "B202302" ;
  u2:email "neha.kulkarni@beacon.edu" ;
  u2:memberOfSchool u2:CSE ;
  u2:followsTrack u2:BTech_CS ;
  u2:studiesAtInstitute u2:BeaconInstitute ;
  u2:enrolledIn u2:CS101 .

