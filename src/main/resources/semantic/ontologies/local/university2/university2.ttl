  u2:displayName "Harsh Patel" ;
  u2:learnerId "B202303" ;
  u2:email "harsh.patel@beacon.edu" ;
  u2:memberOfSchool u2:CSE ;
  u2:followsTrack u2:BTech_CS ;
  u2:studiesAtInstitute u2:BeaconInstitute ;
  u2:enrolledIn u2:CS102 .

