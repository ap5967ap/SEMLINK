  u2:displayName "Riya Sen" ;
  u2:learnerId "B202304" ;
  u2:email "riya.sen@beacon.edu" ;
  u2:memberOfSchool u2:AIDS ;
  u2:followsTrack u2:BTech_AI ;
  u2:studiesAtInstitute u2:AnalyticsInstitute ;
  u2:enrolledIn u2:AI201 .

u2:S005 a u2:Learner ;
  u2:displayName "Vasu Aggarwal" ;
  u2:learnerId "B202305" ;
  u2:email "vasu@beacon.edu" ;
  u2:memberOfSchool u2:AIDS ;
  u2:followsTrack u2:BTech_AI ;
  u2:studiesAtInstitute u2:AnalyticsInstitute ;
  u2:enrolledIn u2:AI201, u2:DS202 .

u2:S006 a u2:Learner ;
  u2:displayName "Ishita Rao" ;
  u2:learnerId "B202306" ;
  u2:email "ishita.rao@beacon.edu" ;
  u2:memberOfSchool u2:AIDS ;
  u2:followsTrack u2:BTech_AI ;
  u2:studiesAtInstitute u2:AnalyticsInstitute ;
  u2:enrolledIn u2:DS202 .
